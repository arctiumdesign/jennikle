<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Impressum – Arctium Design</title>
  <link rel="icon" type="image/png" href="img/favicon.png" />
  <link rel="stylesheet" href="style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    .impressum-hero {
      background: var(--noir);
      padding: 10rem 0 5rem;
      position: relative;
      overflow: hidden;
    }
    .impressum-hero__bg {
      position: absolute;
      top: -20%; right: -10%;
      width: 50vw; height: 80vh;
      background: radial-gradient(ellipse at 60% 40%, rgba(196,98,45,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .impressum-hero .label { color: var(--copper-light); }
    .impressum-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 300;
      color: var(--cream);
      line-height: 1.1;
      margin-bottom: 0;
    }
    .impressum-body {
      background: var(--cream);
      padding: 5rem 0 7rem;
    }
    .impressum-body .container {
      max-width: 760px;
    }
    .impressum-block {
      margin-bottom: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--cream-warm);
    }
    .impressum-block:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .impressum-block h2 {
      font-size: 1.1rem;
      font-weight: 500;
      font-family: var(--font-body);
      color: var(--copper);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .impressum-block p {
      color: var(--text);
      line-height: 1.9;
      margin-bottom: 0.4rem;
    }
    .impressum-block a {
      color: var(--copper);
      transition: color 0.3s;
    }
    .impressum-block a:hover { color: var(--copper-dark); }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--copper);
      margin-bottom: 3rem;
      transition: gap 0.3s;
    }
    .back-link:hover { gap: 0.8rem; }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav scrolled" id="nav">
    <a href="index.html" class="nav__logo">
      <img src="img/logo-h.png" alt="Arctium Design" class="nav__logo-img" />
    </a>
    <button class="nav__burger" id="burger" aria-label="Menü öffnen">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav__links" id="navLinks">
      <li><a href="index.html#about">Über mich</a></li>
      <li><a href="index.html#leistungen">Leistungen</a></li>
      <li><a href="index.html#arbeiten">Arbeiten</a></li>
      <li><a href="index.html#kontakt" class="nav__cta">Kontakt</a></li>
    </ul>
  </nav>

